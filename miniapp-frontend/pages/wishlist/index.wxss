.page { min-height: 100vh; background: #f5f7fc; padding: 20rpx; }
.tip { background: #ebf2ff; color: #3656a5; border-radius: 12rpx; padding: 16rpx; font-size: 22rpx; margin-bottom: 14rpx; }
.item { background: #fff; border-radius: 14rpx; padding: 20rpx; margin-bottom: 12rpx; }
.title { display: block; font-size: 28rpx; font-weight: 700; color: #1f2738; }
.desc { display: block; margin-top: 8rpx; color: #65708a; font-size: 23rpx; }
