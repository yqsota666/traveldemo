.page { min-height: 100vh; background: #f5f7fc; }
.hero { width: 100%; height: 380rpx; }
.card { margin: 20rpx; background: #ffffff; border-radius: 16rpx; padding: 20rpx; }
.title { display: block; font-size: 32rpx; color: #1d2436; font-weight: 700; }
.tag {
  display: inline-block;
  margin-top: 10rpx;
  padding: 6rpx 12rpx;
  background: #f1e8ff;
  color: #5e438b;
  border-radius: 999rpx;
  font-size: 22rpx;
}
.desc { display: block; margin-top: 12rpx; color: #5f6983; font-size: 24rpx; line-height: 1.6; }
.actions { display: flex; gap: 14rpx; margin: 0 20rpx; }
.action-btn { flex: 1; text-align: center; border-radius: 12rpx; padding: 18rpx 0; font-size: 26rpx; }
.action-btn.ghost { border: 1rpx solid #d8deed; color: #425072; background: #ffffff; }
.action-btn.primary { background: #5a61f0; color: #ffffff; }
