.container {
  padding: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.subtitle {
  color: #666666;
  margin-bottom: 24rpx;
}

.login-flag {
  margin-bottom: 16rpx;
  color: #0f172a;
  font-size: 28rpx;
}

.divider {
  height: 1rpx;
  background: #e5e7eb;
  margin: 24rpx 0;
}

button {
  margin-bottom: 16rpx;
}

.phone-input {
  width: 100%;
  box-sizing: border-box;
  height: 76rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  background: #ffffff;
  padding: 0 20rpx;
  margin-bottom: 16rpx;
}

.result {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #ffffff;
  word-break: break-all;
  white-space: pre-wrap;
}
