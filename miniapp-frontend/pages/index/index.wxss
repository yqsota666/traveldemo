.page { height: 100vh; background: #f4f6fb; }
.scroll { height: 100vh; }
.banner-swiper { height: 460rpx; }
.banner-image { width: 100%; height: 100%; }
.panel {
  margin: 20rpx 20rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
}
.pretrip-entry {
  border-radius: 18rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #4776e6, #8e54e9);
  color: #ffffff;
}
.pretrip-title { font-size: 34rpx; font-weight: 700; }
.pretrip-desc { display: block; margin-top: 10rpx; font-size: 24rpx; opacity: 0.95; }
.block-title { margin: 26rpx 0 14rpx; color: #1f2533; font-size: 30rpx; font-weight: 700; }
.city-card, .hotel-card {
  position: relative;
  height: 170rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.city-card-disabled { filter: grayscale(1); opacity: 0.85; }
.city-bg, .hotel-bg { width: 100%; height: 100%; }
.city-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(17, 22, 35, 0.1), rgba(17, 22, 35, 0.62));
}
.city-copy, .hotel-copy {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.city-name, .hotel-name { color: #ffffff; font-size: 32rpx; font-weight: 700; }
.city-status {
  color: #ffffff;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  background: rgba(0, 0, 0, 0.25);
  border-radius: 999rpx;
}
.hotel-tag {
  color: #5e438b;
  background: #f1e8ff;
  border-radius: 999rpx;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
}
.bottom-space { height: 180rpx; }
.consult-fab {
  position: fixed;
  right: 22rpx;
  bottom: 150rpx;
  background: #6d4edd;
  color: #ffffff;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  z-index: 20;
}
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  display: flex;
  border-top: 1rpx solid #e6e9f2;
  background: #ffffff;
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-item { flex: 1; display: flex; align-items: center; justify-content: center; }
.tab-text { color: #8189a3; font-size: 24rpx; }
.tab-text.active { color: #3355d6; font-weight: 700; }
