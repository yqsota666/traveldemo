<view class="page">
  <view class="header">{{cityName}}定制服务</view>
  <view class="container">
    <view class="left-nav">
      <block wx:for="{{categoryList}}" wx:key="*this">
        <view
          class="nav-item {{activeCategory === item ? 'active' : ''}}"
          bindtap="handleCategoryTap"
          data-category="{{item}}"
        >
          {{item}}
        </view>
      </block>
    </view>
    <view class="content">
      <block wx:for="{{cardList}}" wx:key="id">
        <view class="card" bindtap="handleCardTap" data-id="{{item.id}}">
          <text class="title">{{item.title}}</text>
          <text class="desc">{{item.desc}}</text>
        </view>
      </block>
    </view>
  </view>
</view>
