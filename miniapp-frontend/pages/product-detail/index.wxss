.page { min-height: 100vh; background: #f5f7fc; padding-bottom: 60rpx; }
.cover { width: 100%; height: 360rpx; }
.card { margin: 20rpx; background: #fff; border-radius: 14rpx; padding: 20rpx; }
.title { display: block; font-size: 30rpx; font-weight: 700; color: #21293a; }
.desc { display: block; margin-top: 10rpx; color: #616d86; font-size: 24rpx; line-height: 1.6; }
.cta {
  margin: 0 20rpx;
  text-align: center;
  background: #2f58d6;
  color: #fff;
  border-radius: 12rpx;
  padding: 18rpx 0;
  font-size: 26rpx;
}
