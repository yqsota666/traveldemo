.page { height: 100vh; background: #f5f7fc; }
.section { margin: 16rpx 20rpx 0; background: #fff; border-radius: 14rpx; padding: 20rpx; }
.title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2538; margin-bottom: 12rpx; }
.text { color: #606a84; font-size: 24rpx; line-height: 1.6; }
.guide-grid { display: flex; gap: 12rpx; }
.guide-card { flex: 1; border: 1rpx solid #edf0f7; border-radius: 12rpx; padding: 14rpx; }
.avatar { width: 88rpx; height: 88rpx; border-radius: 50%; }
.name { display: block; margin-top: 8rpx; font-size: 26rpx; font-weight: 700; color: #222b3e; }
.meta { display: block; margin-top: 6rpx; color: #667089; font-size: 21rpx; }
.masonry { display: flex; gap: 10rpx; }
.shot { flex: 1; height: 180rpx; border-radius: 10rpx; }
.shot.tall { height: 220rpx; }
.logo-wall { display: flex; gap: 10rpx; flex-wrap: wrap; }
.logo-item { padding: 14rpx 18rpx; background: #f3f6fc; border-radius: 10rpx; font-size: 22rpx; color: #4e5873; }
