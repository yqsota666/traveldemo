.page { min-height: 100vh; background: #f5f7fc; padding: 20rpx; }
.top { background: #fff; border-radius: 14rpx; padding: 20rpx; }
.name { display: block; font-size: 30rpx; font-weight: 700; color: #20283a; }
.score { display: block; margin-top: 10rpx; color: #5f6a84; font-size: 24rpx; }
.login-tip { margin-top: 12rpx; background: #fff6e8; color: #a46e21; border-radius: 12rpx; padding: 16rpx; font-size: 23rpx; }
.menu { margin-top: 14rpx; background: #fff; border-radius: 14rpx; }
.item { padding: 22rpx; border-bottom: 1rpx solid #edf0f7; color: #273048; font-size: 26rpx; }
.item:last-child { border-bottom: none; }
