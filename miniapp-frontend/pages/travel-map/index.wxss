.page { min-height: 100vh; background: #f5f7fc; padding: 20rpx; }
.map-card { background: #fff; border-radius: 14rpx; padding: 20rpx; }
.title { display: block; color: #20283a; font-size: 30rpx; font-weight: 700; }
.map-image { width: 100%; height: 380rpx; border-radius: 12rpx; margin-top: 12rpx; }
.tip { display: block; margin-top: 10rpx; color: #667088; font-size: 22rpx; }
