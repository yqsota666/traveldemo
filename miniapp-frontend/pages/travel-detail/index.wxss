.page { min-height: 100vh; background: #f4f6fb; padding-bottom: 150rpx; }
.photo-swiper { height: 360rpx; }
.photo { width: 100%; height: 100%; }
.section {
  margin: 16rpx 20rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
}
.title { font-size: 30rpx; font-weight: 700; color: #1f2638; margin-bottom: 10rpx; }
.text { color: #606a84; font-size: 24rpx; line-height: 1.6; }
.consult-fab {
  position: fixed;
  right: 24rpx;
  bottom: 40rpx;
  z-index: 10;
  background: #6a4de2;
  color: #ffffff;
  border-radius: 999rpx;
  padding: 16rpx 26rpx;
  font-size: 24rpx;
}
