.page { min-height: 100vh; background: #f5f7fc; padding: 20rpx; }
.add-btn { text-align: center; background: #4f70ea; color: #fff; border-radius: 12rpx; padding: 18rpx 0; margin-bottom: 14rpx; }
.item { background: #fff; border-radius: 14rpx; padding: 20rpx; margin-bottom: 12rpx; }
.title { display: block; font-size: 28rpx; color: #1f2738; font-weight: 700; }
.note { display: block; margin-top: 8rpx; color: #616c86; font-size: 23rpx; }
.family { display: block; margin-top: 8rpx; color: #8790a8; font-size: 21rpx; }
